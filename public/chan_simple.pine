//@version=5
indicator("Chan", overlay=true, max_lines_count=500, max_boxes_count=200, max_labels_count=200, max_bars_back=1000)

// ── 分型 ──
top_fx = high[2] < high[1] and high[1] > high[0] and high[1] > high[3] and high[1] > high[4]
bot_fx = low[2] > low[1] and low[1] < low[0] and low[1] < low[3] and low[1] < low[4]

var float fx_vals = array.new_float(0)
var int   fx_bars = array.new_int(0)
var bool  fx_tops = array.new_bool(0)
var float fx_prices = array.new_float(0)

if top_fx or bot_fx
    float p = top_fx ? high[1] : low[1]
    if array.size(fx_prices) == 0
        array.push(fx_prices, p); array.push(fx_tops, top_fx); array.push(fx_vals, p); array.push(fx_bars, bar_index[1])
    else
        bool last_top = array.last(fx_tops)
        if last_top == top_fx
            if (top_fx and p > array.last(fx_prices)) or (bot_fx and p < array.last(fx_prices))
                array.pop(fx_prices); array.pop(fx_tops); array.pop(fx_vals); array.pop(fx_bars)
                array.push(fx_prices, p); array.push(fx_tops, top_fx); array.push(fx_vals, p); array.push(fx_bars, bar_index[1])
        else
            array.push(fx_prices, p); array.push(fx_tops, top_fx); array.push(fx_vals, p); array.push(fx_bars, bar_index[1])

// ── 笔 ──
var float bi_s_x = array.new_float(0); var int bi_s_b = array.new_int(0)
var float bi_e_x = array.new_float(0); var int bi_e_b = array.new_int(0)
var bool  bi_ups = array.new_bool(0)
var int   last_bi_end = 0

if array.size(fx_prices) >= 2
    int n = array.size(fx_prices)
    bool t0 = array.get(fx_tops, n-2); bool t1 = array.get(fx_tops, n-1)
    int b0 = array.get(fx_bars, n-2); int b1 = array.get(fx_bars, n-1)
    if t0 != t1 and b0 != b1 and b1 >= last_bi_end + 3
        array.push(bi_s_x, array.get(fx_vals, n-2)); array.push(bi_s_b, b0)
        array.push(bi_e_x, array.get(fx_vals, n-1)); array.push(bi_e_b, b1)
        array.push(bi_ups, not t0)
        last_bi_end := b1

for i = 0 to array.size(bi_s_x) - 1
    color c = array.get(bi_ups, i) ? #00aa00 : #ff3333
    line.new(array.get(bi_s_b, i), array.get(bi_s_x, i), array.get(bi_e_b, i), array.get(bi_e_x, i), color=c, width=2)

// ── 段 ──
var float sg_s_x = array.new_float(0); var int sg_s_b = array.new_int(0)
var float sg_e_x = array.new_float(0); var int sg_e_b = array.new_int(0)
var bool  sg_ups = array.new_bool(0)

if array.size(bi_ups) >= 3
    for k = 2 to array.size(bi_ups) - 1
        bool u0 = array.get(bi_ups, k-2); bool u1 = array.get(bi_ups, k-1); bool u2 = array.get(bi_ups, k)
        if u0 != u1 and u1 != u2
            int sb = array.get(bi_s_b, k-2); int eb = array.get(bi_e_b, k)
            bool add = array.size(sg_s_b) == 0 or array.last(sg_s_b) != sb
            if add
                array.push(sg_s_x, array.get(bi_s_x, k-2)); array.push(sg_s_b, sb)
                array.push(sg_e_x, array.get(bi_e_x, k)); array.push(sg_e_b, eb)
                array.push(sg_ups, array.get(bi_e_x, k) > array.get(bi_s_x, k-2))

for i = 0 to array.size(sg_s_x) - 1
    line.new(array.get(sg_s_b, i), array.get(sg_s_x, i), array.get(sg_e_b, i), array.get(sg_e_x, i), color=#9900ff, width=3)

// ── 中枢 (3段重叠) ──
if array.size(sg_s_b) >= 3
    for k = 2 to array.size(sg_s_b) - 1
        float h0 = math.max(array.get(sg_s_x, k-2), array.get(sg_e_x, k-2))
        float l0 = math.min(array.get(sg_s_x, k-2), array.get(sg_e_x, k-2))
        float h1 = math.max(array.get(sg_s_x, k-1), array.get(sg_e_x, k-1))
        float l1 = math.min(array.get(sg_s_x, k-1), array.get(sg_e_x, k-1))
        float h2 = math.max(array.get(sg_s_x, k-0), array.get(sg_e_x, k-0))
        float l2 = math.min(array.get(sg_s_x, k-0), array.get(sg_e_x, k-0))
        float top = math.min(h0, h1, h2); float bot = math.max(l0, l1, l2)
        if top > bot
            box.new(array.get(sg_s_b, k-2), top, array.get(sg_e_b, k), bot, bgcolor=color.new(color.blue, 93), border_color=color.new(color.blue, 50))

// ── BSP 买卖点 ──
if array.size(sg_s_b) >= 1 and array.size(bi_ups) >= 2
    // 最新段
    int sn = array.size(sg_s_b)
    int bn = array.size(bi_ups)
    bool seg_up  = array.get(sg_ups, sn-1)
    bool last_up = array.get(bi_ups, bn-1)
    bool prev_up = array.get(bi_ups, bn-2)
    int  lsb     = array.get(bi_s_b, bn-1)
    int  leb     = array.get(bi_e_b, bn-1)
    float lsp    = array.get(bi_s_x, bn-1)
    float lep    = array.get(bi_e_x, bn-1)

    // 一买
    if not seg_up and last_up and not prev_up
        label.new(lsb, lsp, "B1", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.tiny)
    // 一卖
    if seg_up and not last_up and prev_up
        label.new(lsb, lsp, "S1", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.tiny)

// ── 信息表 ──
var table t = table.new(position.top_right, 1, 3, bgcolor=color.new(#000000, 85))
if barstate.islast
    table.cell(t, 0, 0, "Chan 缠论", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "笔:" + str.tostring(array.size(bi_s_x)) + " 段:" + str.tostring(array.size(sg_s_x)), text_color=#aaaaaa, text_size=size.small)
    table.cell(t, 0, 2, "中枢:" + str.tostring(box_count) + "  分型:" + str.tostring(array.size(fx_prices)), text_color=#aaaaaa, text_size=size.small)
